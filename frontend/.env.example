# ── Required ──────────────────────────────────────────────────────────────────

# Public backend URL (used by Next.js API route proxies when BACKEND_URL is unset)
NEXT_PUBLIC_API_URL=https://api.your-backend.example.com

# ── Recommended for Docker / private networks ────────────────────────────────

# Server-side proxy target (takes precedence over NEXT_PUBLIC_API_URL).
# Use the internal service hostname so traffic stays on your private network.
# BACKEND_URL=http://backend:8000
