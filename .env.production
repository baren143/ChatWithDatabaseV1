# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this file to .env.production and fill in all values
# ============================================================================

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here_min_32_chars_strongly_recommended
POSTGRES_DB=chat_db_prod

# Redis Configuration (with password for security)
REDIS_PASSWORD=your_secure_redis_password_here_min_32_chars

# API Configuration
JWT_SECRET_KEY=your_secure_jwt_secret_key_here_min_32_chars_use_strong_random

# NVIDIA API (LLM Provider)
NVIDIA_API_KEY=your_nvidia_api_key_here

# CORS Configuration - Set to your frontend domain(s)
# Format: https://yourdomain.com or multiple with comma separation
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Frontend API URL - should point to your backend domain
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ============================================================================
# SECURITY NOTES
# ============================================================================
# 1. Generate strong passwords using: openssl rand -base64 32
# 2. Use environment-specific secrets in your VPS (don't commit this file)
# 3. Store secrets in a secure vault (HashiCorp Vault, AWS Secrets Manager, etc.)
# 4. Rotate all secrets regularly
# 5. Use HTTPS/TLS for all external communications
# 6. Use a reverse proxy (nginx) to handle SSL termination
# 7. Regularly update Docker images: docker-compose pull
# 8. Monitor container logs: docker-compose logs -f
# ============================================================================
