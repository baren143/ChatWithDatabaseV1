# Environment variables for Chat with Database v1
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=chat_db
DATABASE_URL=postgresql+psycopg://postgres:postgres_password@localhost:5432/chat_db
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=your_secret_key_for_jwt_here_min_32_chars
NVIDIA_API_KEY=dummy_key_for_testing
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080