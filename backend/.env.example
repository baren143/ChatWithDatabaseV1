# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL + pgvector (use your host, or `db` on Docker Compose)
DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME@db:5432/chat_db

# Redis broker for Celery workers
REDIS_URL=redis://redis:6379/0

# Comma-separated browser origins allowed to call the API (no trailing slashes)
ALLOWED_ORIGINS=https://your-frontend.example.com

# NVIDIA NIM / API key for embeddings and LLM
NVIDIA_API_KEY=

# JWT signing secret (required if auth routes are enabled)
JWT_SECRET_KEY=generate-a-long-random-string-here

# ── Optional: connection pool tuning ─────────────────────────────────────────

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800
DB_POOL_TIMEOUT=30

# ── Optional: Celery / Redis ─────────────────────────────────────────────────

CELERY_BROKER_POOL_LIMIT=10
REDIS_MAX_CONNECTIONS=20

# ── Optional: pgvector index ─────────────────────────────────────────────────

PGVECTOR_INDEX_TYPE=hnsw
PGVECTOR_HNSW_M=16
PGVECTOR_HNSW_EF_CONSTRUCTION=64

# ── Optional: debug logging (never enable in production) ─────────────────────

# DEBUG=true
